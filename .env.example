# ─── WHOOP OAuth Credentials ───────────────────────────────
#
# 1. Go to https://developer-dashboard.whoop.com
# 2. Click "Create New Application" (or open your existing app)
# 3. Set the redirect URI to:  http://localhost:3000/callback
# 4. Enable scopes: read:recovery, read:sleep, read:workout, read:cycles, read:profile
# 5. Copy your Client ID and Client Secret below
# 6. Rename this file to .env
#
# ────────────────────────────────────────────────────────────

WHOOP_CLIENT_ID=your_client_id_here
WHOOP_CLIENT_SECRET=your_client_secret_here
WHOOP_REDIRECT_URI=http://localhost:3000/callback

PORT=3000

# ─── ClickUp Integration ───────────────────────────────────
#
# 1. Go to https://app.clickup.com/settings/apps
# 2. Click "Generate" under Personal API Token
# 3. Paste the token below
#
# ────────────────────────────────────────────────────────────

CLICKUP_API_TOKEN=your_clickup_api_token_here

# Your ClickUp user ID (numeric). Find it via GET /api/v2/user
# or leave blank to auto-detect from the API token owner.
CLICKUP_USER_ID=

# ClickUp team/workspace ID. Required for fetching tasks.
# Find it at: Settings > Workspace > look at URL or use GET /api/v2/team
CLICKUP_TEAM_ID=

# ─── Google Calendar Integration ──────────────────────────
#
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add redirect URI: http://localhost:3000/auth/google/callback
# 4. Enable the Google Calendar API
# 5. Copy Client ID and Secret below
#
# ────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
